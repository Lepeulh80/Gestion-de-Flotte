# ============================================================
# CONFIGURATION - Fleet Manager API
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# Mode d'exécution : development | production
NODE_ENV=production

# Port du serveur (Hostinger VPS : utiliser 3001 derrière Nginx)
PORT=3001

# JWT Secret — OBLIGATOIRE en production
# Générer: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REMPLACER_PAR_UNE_CLE_ALEATOIRE_DE_64_CHARS

# Durée d'expiration du token JWT
JWT_EXPIRES=8h

# CORS — Mettre votre domaine Hostinger
# Exemple: https://ncmali.com,https://www.ncmali.com
ALLOWED_ORIGINS=https://votre-domaine.com,https://www.votre-domaine.com

# Chemin base de données (relatif au dossier backend/)
# DATABASE_PATH=./fleet.db

# Logging
LOG_LEVEL=info
